generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id                String              @id @default(uuid())
  sku               String              @unique
  name              String
  priceBuy          Float?
  priceRetail       Float
  priceWholesale    Float?
  wholesaleMinQty   Int?                @default(0)
  stock             Int                 @default(0)
  minStockAlert     Int                 @default(5)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  TransactionDetail TransactionDetail[]
  PoItem            PoItem[]
  StockLog          StockLog[]
}

model Member {
  id          String        @id @default(uuid())
  phone       String        @unique
  name        String
  joinedAt    DateTime      @default(now())
  Transaction Transaction[]
}

model Transaction {
  id             String              @id @default(uuid())
  receiptNumber  String              @unique
  memberId       String?
  totalAmount    Float
  discountAmount Float               @default(0)
  paymentMethod  String              @default("cash")
  cashReceived   Float?
  change         Float?
  approvalCode   String?
  cashierName    String              @default("Admin")
  shiftId        String?
  isVoid         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  member         Member?             @relation(fields: [memberId], references: [id])
  details        TransactionDetail[]
  VoidLog        VoidLog?

  @@index([createdAt])
  @@index([isVoid])
  @@index([shiftId])
  @@index([memberId])
  @@index([createdAt, isVoid])
  @@index([createdAt, cashierName])
}

model TransactionDetail {
  id             String      @id @default(uuid())
  transactionId  String
  productId      String
  quantity       Int
  priceBuyAtTime Float?
  priceAtTime    Float
  subtotal       Float
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product        Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model MemberTier {
  id                 String   @id @default(uuid())
  name               String   @unique
  minTransactions    Int      @default(0)
  minTotalSpent      Float    @default(0)
  minOrderAmount     Float    @default(0)
  discountPercentage Float    @default(0)
  maxDiscountAmount  Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SyncQueue {
  id           String   @id @default(uuid())
  tableName    String
  recordId     String
  operation    String
  payload      String
  status       String   @default("PENDING")
  errorMessage String?
  retryCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Employee {
  id         String       @id @default(uuid())
  name       String
  phone      String?
  role       String       @default("kasir")
  isActive   Boolean      @default(true)
  wageBase   Float        @default(0)
  wageSolo   Float        @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Attendance Attendance[]
  Expense    Expense[]
}

model Shift {
  id         String       @id @default(uuid())
  name       String
  startTime  String
  endTime    String
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  Attendance Attendance[]
  Expense    Expense[]
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  shiftId     String?
  date        DateTime  @default(now())
  checkIn     DateTime?
  checkOut    DateTime?
  notes       String?
  hoursWorked Float?
  wageUsed    Float?
  totalWage   Float?
  isSolo      Boolean?  @default(false)
  createdAt   DateTime  @default(now())
  employee    Employee  @relation(fields: [employeeId], references: [id])
  shift       Shift?    @relation(fields: [shiftId], references: [id])

  @@index([date])
  @@index([employeeId])
  @@index([shiftId])
}

model StoreStatus {
  id        String   @id @default("local-store")
  lastPing  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreProfile {
  id        String   @id @default("local-store")
  name      String   @default("TokoKu")
  address   String   @default("")
  phone     String   @default("")
  city      String   @default("")
  footer    String   @default("Terima kasih telah berbelanja!")
  logoUrl   String?
  latitude  Float?
  longitude Float?
  radius    Int      @default(50)
  voidPin   String   @default("123456")
  updatedAt DateTime @updatedAt
}
model Expense {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  category    String
  amount      Float
  notes       String?
  employeeId  String
  shiftId     String?
  syncStatus  String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])
  shift       Shift?   @relation(fields: [shiftId], references: [id])

  @@index([date])
  @@index([syncStatus])
  @@index([employeeId])
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  PurchaseOrder PurchaseOrder[]
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  supplierId  String?
  date        DateTime @default(now())
  totalAmount Float
  notes       String?
  syncStatus  String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  items       PoItem[]

  @@index([date])
  @@index([syncStatus])
  @@index([supplierId])
}

model PoItem {
  id              String        @id @default(uuid())
  poId            String
  productId       String
  quantity        Int
  priceBuy        Float
  subtotal        Float
  purchaseOrder   PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([poId])
  @@index([productId])
}

model StockLog {
  id          String   @id @default(uuid())
  productId   String
  type        String   // IN, OUT, CORRECTION, VOID_RETURN
  amount      Int
  stockBefore Int
  stockAfter  Int
  notes       String?
  referenceId String?  // ID transaksi atau PO
  employeeId  String?  // Kasir yang melakukan (opsional krn auto-sync kadang tidak tahu)
  date        DateTime @default(now())
  syncStatus  String   @default("PENDING")
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([date])
  @@index([syncStatus])
}

model VoidLog {
  id            String      @id @default(uuid())
  transactionId String      @unique
  reason        String      // SALAH_INPUT, RETUR_PELANGGAN, LAINNYA
  notes         String?
  employeeId    String?     // Nama kasir atau supervisor yang melakukan void
  date          DateTime    @default(now())
  syncStatus    String      @default("PENDING")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([date])
  @@index([syncStatus])
}
