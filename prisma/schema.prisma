generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id                String              @id @default(uuid())
  sku               String              @unique
  name              String
  priceRetail       Float
  priceWholesale    Float?
  wholesaleMinQty   Int?                @default(0)
  stock             Int                 @default(0)
  minStockAlert     Int                 @default(5)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  TransactionDetail TransactionDetail[]
}

model Member {
  id          String        @id @default(uuid())
  phone       String        @unique
  name        String
  joinedAt    DateTime      @default(now())
  Transaction Transaction[]
}

model Transaction {
  id             String              @id @default(uuid())
  receiptNumber  String              @unique
  memberId       String?
  totalAmount    Float
  discountAmount Float               @default(0)
  paymentMethod  String              @default("cash")
  cashReceived   Float?
  change         Float?
  approvalCode   String?
  cashierName    String              @default("Admin")
  shiftId        String?
  isVoid         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  member         Member?             @relation(fields: [memberId], references: [id])
  details        TransactionDetail[]
}

model TransactionDetail {
  id            String      @id @default(uuid())
  transactionId String
  productId     String
  quantity      Int
  priceAtTime   Float
  subtotal      Float
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id])
}

model MemberTier {
  id                 String   @id @default(uuid())
  name               String   @unique
  minTransactions    Int      @default(0)
  minTotalSpent      Float    @default(0)
  minOrderAmount     Float    @default(0)
  discountPercentage Float    @default(0)
  maxDiscountAmount  Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SyncQueue {
  id           String   @id @default(uuid())
  tableName    String
  recordId     String
  operation    String
  payload      String
  status       String   @default("PENDING")
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id         String       @id @default(uuid())
  name       String
  phone      String?
  role       String       @default("kasir")
  isActive   Boolean      @default(true)
  wageBase   Float        @default(0)
  wageSolo   Float        @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Attendance Attendance[]
}

model Shift {
  id         String       @id @default(uuid())
  name       String
  startTime  String
  endTime    String
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  Attendance Attendance[]
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  shiftId     String?
  date        DateTime  @default(now())
  checkIn     DateTime?
  checkOut    DateTime?
  notes       String?
  hoursWorked Float?
  wageUsed    Float?
  totalWage   Float?
  isSolo      Boolean?  @default(false)
  createdAt   DateTime  @default(now())
  employee    Employee  @relation(fields: [employeeId], references: [id])
  shift       Shift?    @relation(fields: [shiftId], references: [id])
}

model StoreStatus {
  id        String   @id @default("local-store")
  lastPing  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreProfile {
  id        String   @id @default("local-store")
  name      String   @default("TokoKu")
  address   String   @default("")
  phone     String   @default("")
  city      String   @default("")
  footer    String   @default("Terima kasih telah berbelanja!")
  logoUrl   String?
  latitude  Float?
  longitude Float?
  radius    Int      @default(50)
  updatedAt DateTime @updatedAt
}